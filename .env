# ─── Groq API Key ─────────────────────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ─── Deepgram API Key ──────────────────────────────────────────────────────────
# Get from: https://deepgram.com → Dashboard → API Keys
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── ElevenLabs API Key ────────────────────────────────────────────────────────
# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ─── ElevenLabs Voice ID ───────────────────────────────────────────────────────
# Get from: https://elevenlabs.io → Voices → Your cloned voice → Voice ID
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# ─── Transfer Number ───────────────────────────────────────────────────────────
# Doctor/Staff ka number jahan risky calls transfer hongi
TRANSFER_NUMBER=+91XXXXXXXXXX
